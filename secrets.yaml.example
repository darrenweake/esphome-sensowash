# Copy this file to `secrets.yaml` and fill in your values.
# secrets.yaml is git-ignored and is NEVER committed — keep your real values only there.

wifi_ssid: "YourWiFiName"
wifi_password: "YourWiFiPassword"

# Your toilet's Bluetooth MAC address (find it with a BLE scanner app).
toilet_mac: "AA:BB:CC:DD:EE:FF"

# The toilet's 4-byte handshake key, as 8 hex chars.
# If you don't know it, the firmware can LEARN it via enrollment: comment out the
# `handshake_key: !secret handshake_key` line in config.yaml (so NO key is configured),
# flash, then press the toilet's physical Bluetooth button. When the log prints
# "Learned handshake key XXXXXXXX" it is saved to the ESP's flash automatically and reused
# forever. Then paste that value below and re-enable the config.yaml line.
# (NOTE: leaving this at 00000000 does NOT enroll — it sets 00000000 as the key and skips it.)
handshake_key: "00000000"

# Password required to push OTA firmware updates to the board. Choose your own.
ota_password: "choose-a-strong-password"
